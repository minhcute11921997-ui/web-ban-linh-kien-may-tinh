# Database
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=yourpassword
DB_NAME=ecommerce_db

# JWT
JWT_SECRET=your_jwt_secret_key_here
JWT_REFRESH_SECRET=your_jwt_refresh_secret_key_here

# CORS — danh sách origin cho phép, phân cách bằng dấu phẩy, KHÔNG có dấu cách
ALLOWED_ORIGINS=http://localhost:5173,https://yourdomain.com

# VNPay (đăng ký tại https://sandbox.vnpayment.vn/devreg/)
VNPAY_TMN_CODE=your_tmn_code
VNPAY_SECRET_KEY=your_secret_key
# URL VNPay redirect về sau thanh toán — phải khớp với PORT bên dưới
VNPAY_RETURN_URL=http://localhost:3000/api/payments/vnpay-callback

# URL frontend để backend redirect sau khi xử lý callback
FRONTEND_URL=http://localhost:5173

# Google Sign-In
# Tao OAuth 2.0 Client ID loai Web application trong Google Cloud Console.
# Authorized JavaScript origins can co http://localhost:5173 khi dev local.
GOOGLE_CLIENT_ID=your_google_oauth_web_client_id.apps.googleusercontent.com

# Server
PORT=3000
