# ===== CẤU HÌNH SERVER =====
PORT=3000

# ===== CẤU HÌNH DATABASE (MySQL) =====
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=ecommerce_db
DB_PORT=3306

# ===== CẤU HÌNH JWT =====
# Access token - dùng để xác thực API (hết hạn 24h)
JWT_SECRET=your_jwt_secret_here

# Refresh token - dùng để làm mới access token (hết hạn 7 ngày)
JWT_REFRESH_SECRET=your_jwt_refresh_secret_here

# ===== CẤU HÌNH VNPAY =====
# Lấy từ VNPay sandbox hoặc production
VNPAY_TMN_CODE=your_tmncode_here
VNPAY_SECRET_KEY=your_secret_key_here
VNPAY_RETURN_URL=http://localhost:5173/payment-callback