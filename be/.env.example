# SERVER
PORT=3000

# DATABASE (MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=ecommerce_db
DB_PORT=3306

# JWT
JWT_SECRET=replace-with-long-random-access-token-secret
JWT_REFRESH_SECRET=replace-with-long-random-refresh-token-secret

# VNPAY
VNPAY_TMN_CODE=your-vnpay-tmn-code
VNPAY_HASH_SECRET=your-vnpay-hash-secret
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:3000/api/payments/vnpay-callback

# FRONTEND
FRONTEND_URL=http://localhost:5173

# GOOGLE LOGIN
GOOGLE_CLIENT_ID=your-google-client-id
VITE_GOOGLE_CLIENT_ID=your-google-client-id

# EMAIL VERIFICATION (Gmail SMTP - use Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-gmail@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM="PC Shop <your-gmail@gmail.com>"

# AI
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash
AI_LAB_URL=http://127.0.0.1:4001
AI_LAB_TIMEOUT_MS=15000
